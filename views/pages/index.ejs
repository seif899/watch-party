<!DOCTYPE html>
<html>
<head>
  <%- include ("../partials/header.ejs") %>
</head>

<body>

  <%- include ("../partials/nav.ejs") %>
    <input type="text" id="link-injector">
    <button id="load">load</button>

    <script>
      let count=0
      function handleClick(){
        //search for video
        const link=document.getElementById("link-injector").value;
        fetch(`https://www.googleapis.com/youtube/v3/search?part=snippet&maxResults=1&q=${link}&key=AIzaSyCS_8M26113YwMd6SS8z0okR4z11-0HikA`)
        .then(response=>response.json())
        .then(data=>{
          console.log(count);
          console.log(data);
          const videoId=data.items[0].id.videoId;
          if (count){
            player.loadVideoById(videoId)
          }
          scr=document.createElement("script");
          scr.innerHTML=`console.log("${videoId}");var tag = document.createElement('script');tag.src = 'https://www.youtube.com/iframe_api';var firstScriptTag = document.getElementsByTagName('script')[0];firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);var player;function onYouTubeIframeAPIReady(videoId) {console.log('ha');player = new YT.Player('player', { height: '390', width: '640', videoId: "${videoId}", playerVars: { 'playsinline': 1 }, events: { 'onReady': onPlayerReady, 'onStateChange': onPlayerStateChange } }); } function onPlayerReady(event) { event.target.playVideo(); } var done = false; function onPlayerStateChange(event) { if (event.data == YT.PlayerState.PLAYING && !done) { done = true; } } function stopVideo() { player.stopVideo(); }`
          document.getElementById("player").appendChild(scr); 
          count=1    
        }) 
        .catch(err=>console.log(err)) 
      } 
      document.getElementById("load").addEventListener("click", handleClick);
    </script>
    <div id="player"></div>


</body>
</html>
